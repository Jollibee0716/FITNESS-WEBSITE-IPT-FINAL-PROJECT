<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Section 5 - Objective</title>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@200;700&family=Inter:wght@400;900&display=swap" rel="stylesheet">
  <style>
    html, body {
      padding: 0; margin: 0; height: 100vh;
      background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.95)), 
                  url('Images/web3.jpg') center/cover no-repeat fixed;
      font-family: 'Times New Roman', Times, serif;
      display: flex; justify-content: center; align-items: center;
    }

    section {
      display: flex; flex-direction: column; justify-content: center; align-items: center;
      width: 100%;
    }

    .section-caption {
      margin-bottom: 40px; color: white; font-size: 40px;
      background: rgba(0,0,0,0.4); padding: 5px 20px; border-radius: 5px;
      font-family: 'Oswald', sans-serif;
    }

    .content { display: flex; gap: 50px; }

    .menu { display: flex; flex-direction: column; gap: 10px; }

    .menu button {
      background: rgb(191, 109, 10); border: none; padding: 15px 25px;
      color: white; border-radius: 20px; cursor: pointer;
      transition: 0.2s; font-size: 16px;
    }

    .menu button:hover { background: #ff9500; }

    .body { position: relative; width: 250px; }
    .body img { width: 100%; display: block; }
    
    .highlight {
      position: absolute; top: 0; left: 0; opacity: 0;
      transition: opacity 0.3s ease;
    }
    .highlight.active { opacity: 1; }
  </style>
</head>
<body>

<section id="section5">
  <div class="section-caption">Select your Target Muscle (Gain Muscle)</div>
  
  <div class="content">
    <div class="menu">
      <button data-target="fullbody" onclick="goToWorkout('fullbody_gain.html')">Full body</button>
      <button data-target="chest" onclick="goToWorkout('chest_gain.html')">Chest</button>
      <button data-target="abs" onclick="goToWorkout('abs_gain.html')">Abs</button>
      <button data-target="bicep" onclick="goToWorkout('bicep_gain.html')">Bicep</button>
      <button data-target="tricep" onclick="goToWorkout('tricep_gain.html')">Tricep</button>
      <button data-target="shoulders" onclick="goToWorkout('shoulders_gain.html')">Shoulders</button>
      <button data-target="back" onclick="goToWorkout('backandtraps_gain.html')">Back and Traps</button>
      <button data-target="butt" onclick="goToWorkout('butt_gain.html')">Butt</button>
      <button data-target="legs" onclick="goToWorkout('legs_gain.html')">Legs</button>
    </div>

    <div class="body">
      <img src="Images/body.png" alt="Body Map">
      <img src="Images/fullbody.png" class="highlight fullbody">
      <img src="Images/chest.png" class="highlight chest">
      <img src="Images/abs.png" class="highlight abs">
      <img src="Images/bicep.png" class="highlight bicep">
      <img src="Images/tricep.png" class="highlight tricep">
      <img src="Images/shoulders.png" class="highlight shoulders">
      <img src="Images/back.png" class="highlight back">
      <img src="Images/butt.png" class="highlight butt">
      <img src="Images/legs.png" class="highlight legs">
    </div>
  </div>
</section>

<script>
  function goToWorkout(url) { window.location.href = url; }

  // Hover logic
  document.querySelectorAll(".menu button").forEach(btn => {
    const targetClass = btn.getAttribute("data-target");
    btn.addEventListener("mouseenter", () => {
      document.querySelector(`.highlight.${targetClass}`).classList.add("active");
    });
    btn.addEventListener("mouseleave", () => {
      document.querySelector(`.highlight.${targetClass}`).classList.remove("active");
    });
  });
</script>

</body>
</html>